  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "Kiểm tra sức khỏe hệ thống",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Functional - Health check trả về 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"Functional - Trạng thái hệ thống phải là UP\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.status).to.eql(\"UP\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Đẩy sự kiện quẹt thẻ hợp lệ",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Functional - Tiếp nhận sự kiện thành công trả về 201 Created\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "pm.test(\"Functional - Trả về đúng schema quyết định phê duyệt\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"access_granted\");\r",
                  "    pm.expect(json).to.have.property(\"person_id\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"event_type\": \"access_event\",\r\n  \"timestamp\": \"2026-05-18T08:30:00Z\",\r\n  \"card_id\": \"RFID-2026-9999\",\r\n  \"gate_id\": \"gate-lib-01\",\r\n  \"direction\": \"IN\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/events/access",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "events",
                "access"
              ]
            }
          },
          "response": []
        }
      ]
    },
