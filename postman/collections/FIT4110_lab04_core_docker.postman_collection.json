    {
      "name": "03_Negative",
      "item": [
        {
          "name": "Truyền thiếu trường bắt buộc để ép lỗi 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Negative - Truyền thiếu trường bắt buộc trả về lỗi 400 Bad Request\", function () {\r",
                  "    pm.response.to.have.status(422);\r",
                  "});\r",
                  "pm.test(\"Negative - Cấu trúc lỗi phải tuân thủ Problem Details chuẩn RFC 7807\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"title\");\r",
                  "    pm.expect(json).to.have.property(\"status\");\r",
                  "    pm.expect(json).to.have.property(\"detail\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Prefer",
                "value": "code=400",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"event_type\": \"access_event\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
